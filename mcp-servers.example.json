{
  "mcpServers": {
    "filesystem": {
      "enabled": true,
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "D:\\path\\to\\allowed\\files"
      ]
    },
    "playwright": {
      "enabled": true,
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--browser",
        "msedge",
        "--output-dir",
        "D:\\path\\to\\playwright-output"
      ]
    },
    "git": {
      "enabled": false,
      "transport": "stdio",
      "command": "D:\\path\\to\\repo\\.venv\\Scripts\\python.exe",
      "args": [
        "D:\\path\\to\\repo\\scripts\\mcp\\git-mcp.py",
        "--repo-root",
        "D:\\path\\to\\git-repo"
      ]
    },
    "docker": {
      "enabled": false,
      "transport": "stdio",
      "command": "D:\\path\\to\\repo\\.venv\\Scripts\\python.exe",
      "args": [
        "D:\\path\\to\\repo\\scripts\\mcp\\docker-mcp.py",
        "--project-root",
        "D:\\path\\to\\docker-project"
      ]
    },
    "uvcs": {
      "enabled": false,
      "transport": "stdio",
      "command": "D:\\path\\to\\repo\\.venv\\Scripts\\python.exe",
      "args": [
        "D:\\path\\to\\repo\\scripts\\mcp\\uvcs-mcp.py",
        "--workspace-root",
        "D:\\path\\to\\unreal-workspace"
      ]
    }
  }
}
