VLLM_IMAGE=vllm/vllm-openai:v0.18.0-cu130
OPEN_WEBUI_IMAGE=openwebui/open-webui:0.8.12
CONTAINER_NAME=local-vllm
HOST_PORT=8000
OPEN_WEBUI_PORT=3010
WEBUI_SECRET_KEY=change-me-local-vllm-open-webui

# Default coding model for this 16 GB GPU.
MODEL_ID=Qwen/Qwen2.5-Coder-14B-Instruct-AWQ
SERVED_MODEL_NAME=qwen2.5-coder-14b-instruct-awq

# Set this if you need gated models from Hugging Face.
HF_TOKEN=
API_KEY=local-vllm-key

DTYPE=auto
TENSOR_PARALLEL_SIZE=1
GPU_MEMORY_UTILIZATION=0.82
MAX_MODEL_LEN=8192
MAX_NUM_SEQS=8
CPU_OFFLOAD_GB=0
TRUST_REMOTE_CODE=false
ENABLE_PREFIX_CACHING=true
ENABLE_AUTO_TOOL_CHOICE=true
TOOL_CALL_PARSER=hermes
CHAT_TEMPLATE=

# Optional extra flags passed directly to `vllm serve`.
# Example: --chat-template /models/templates/chat_template.jinja
EXTRA_ARGS=
